<navigation-bar title="本局确认" color="#1f3625" background="#E9F6EC"></navigation-bar>
<view class="page">
  <scoreboard
    fixedTop="{{true}}"
    editableNames="{{true}}"
    playerNames="{{playerNames}}"
    scoreKeys="{{scoreKeys}}"
    totalScores="{{totalScores}}"
    roundScores="{{roundScores}}"
    bind:editname="handleEditName"
  />

  <view class="page__section">
    <score-summary title="本局合计" playerNames="{{playerNames}}" scoreKeys="{{scoreKeys}}" scores="{{roundScores}}" />
  </view>

  <view class="page__section">
    <view class="feedback-note {{canConfirm ? 'feedback-note--confirm' : 'feedback-note--warning'}}">
      {{confirmHint}}
    </view>
  </view>

  <view class="page__section">
    <view wx:if="{{!currentRound || currentRound.settlements.length === 0}}" class="empty-state">
      <text class="empty-state__title">当前还没有可确认的结算</text>
      <text class="empty-state__text">当前不能，请先返回结果录入页完成至少一条结算。</text>
    </view>
    <settlement-list wx:else settlements="{{currentRound ? currentRound.settlements : []}}" />
  </view>

  <view class="page__section page__actions">
    <button class="ghost-btn" bindtap="handleBack">返回修改</button>
    <button class="primary-btn" bindtap="handleConfirm" disabled="{{!canConfirm}}">确认并累计</button>
  </view>
</view>
