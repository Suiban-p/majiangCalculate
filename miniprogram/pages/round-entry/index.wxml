<navigation-bar title="结果录入" color="#1f3625" background="#E9F6EC"></navigation-bar>
<view class="page">
  <scoreboard
    fixedTop="{{true}}"
    editableNames="{{true}}"
    playerNames="{{playerNames}}"
    scoreKeys="{{scoreKeys}}"
    totalScores="{{totalScores}}"
    roundScores="{{roundScores}}"
    bind:editname="handleEditName"
  />

  <view class="page__section">
    <round-status modeLabel="{{modeLabel}}" remainingText="{{remainingText}}" extraText="{{extraText}}" />
  </view>

  <view class="page__section">
    <view class="logic-hint">{{riverHint}}</view>
  </view>

  <view class="page__section">
    <action-buttons
      canUndo="{{!!currentRound && currentRound.settlements.length > 0}}"
      canFinish="{{canFinishRound}}"
      showChadajiao="{{currentRound && currentRound.config.mode === 'blood_battle'}}"
      bind:hu="openHuForm"
      bind:gang="handleGangTap"
      bind:chadajiao="handleChaDaJiaoTap"
      bind:undo="handleUndo"
      bind:finish="handleFinish"
    />
    <view class="feedback-note {{canFinishRound ? 'feedback-note--confirm' : 'feedback-note--warning'}}">
      {{finishHint}}
    </view>
  </view>

  <view class="page__section">
    <score-summary title="本局实时分" playerNames="{{playerNames}}" scoreKeys="{{scoreKeys}}" scores="{{roundScores}}" />
  </view>

  <view class="page__section">
    <view wx:if="{{!currentRound || currentRound.settlements.length === 0}}" class="empty-state">
      <text class="empty-state__title">当前还没有本局结算</text>
      <text class="empty-state__text">{{emptySettlementText}}</text>
    </view>
    <settlement-list wx:else settlements="{{currentRound ? currentRound.settlements : []}}" editable="{{true}}" bind:delete="handleDeleteSettlement" />
  </view>

  <hu-form
    visible="{{huFormVisible}}"
    config="{{currentRound ? currentRound.config : null}}"
    availableWinners="{{availableWinners}}"
    availableLosers="{{availableLosers}}"
    allowMultipleWinners="{{currentRound && currentRound.config.mode === 'blood_river'}}"
    bind:cancel="closeHuForm"
    bind:confirm="handleHuConfirm"
  />
  <gang-form
    visible="{{gangFormVisible}}"
    config="{{currentRound ? currentRound.config : null}}"
    playerNames="{{activePlayerNames}}"
    bind:cancel="closeGangForm"
    bind:confirm="handleGangConfirm"
  />
  <chadajiao-form
    visible="{{chadajiaoFormVisible}}"
    playerNames="{{playerNames}}"
    bind:cancel="closeChaDaJiaoForm"
    bind:confirm="handleChaDaJiaoConfirm"
  />
</view>
